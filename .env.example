# PostgreSQL Database URL
# Use your Supabase Transaction Pooler URL here to enable Real-time and Storage features:
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres"
# For local Docker fallback (without Real-time): postgresql://postgres:password@localhost:5432/postgres

# Redis (for Background Jobs / BullMQ)
REDIS_URL="redis://localhost:6379"

# Authentication (Better Auth)
AUTH_SECRET="super-secret-key-replace-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (required for File Attachments & Real-time updates)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
